# =========================================================================
# SocialSentry — production environment for docker-compose.prod.yml
# Copy to .env.prod (raw Docker) or paste these into EasyPanel's env field.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d
# =========================================================================

# --- Release version ---
# Image tag WITHOUT the leading "v" (e.g. tag v1.2.0 -> VERSION=1.2.0).
# Use "latest" to track the newest stable release.
VERSION=latest

# --- Database (runs inside the compose; values also build DATABASE_URL) ---
DB_NAME=socialsentry
DB_USER=socialsentry
DB_PASSWORD=change-me-strong-password

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Encryption (AES-256-GCM for platform tokens) ---
# Generate: openssl rand -hex 32   (exactly 64 hex characters = 32 bytes)
ENCRYPTION_KEY=change-me-64-hex-chars

# --- Meta / Instagram ---
META_APP_ID=1388425723092623
META_APP_SECRET=replace_with_real_secret
# Optional: secret of the app that OWNS the webhook subscription (two-app setup).
# If empty, META_APP_SECRET is used.
META_WEBHOOK_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=any-random-string-for-webhook-verify
# Public webhook URL — served through the frontend's nginx proxy on your domain.
META_CALLBACK_URL=https://your-domain.com/webhooks/instagram

# --- VK ---
VK_API_VERSION=5.199

# --- Misc ---
LOG_LEVEL=info

# --- Frontend host port (raw Docker only; EasyPanel uses a domain instead) ---
FRONTEND_PORT=8088
