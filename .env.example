# =========================================================================
# SocialSentry — example environment file
# Copy to .env and fill in real secrets before running `docker compose up`.
# =========================================================================

# --- Database ---
DATABASE_URL=postgres://socialsentry:secret@postgres:5432/socialsentry?sslmode=disable
DB_NAME=socialsentry
DB_USER=socialsentry
DB_PASSWORD=secret

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-32-bytes-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Encryption (AES-256-GCM for platform tokens stored in DB) ---
# Generate: openssl rand -hex 32   (must be exactly 64 hex characters = 32 bytes)
ENCRYPTION_KEY=change-me-32-bytes-hex

# --- Meta / Instagram ---
META_APP_ID=1388425723092623
META_APP_SECRET=replace_with_real_secret
# Секрет приложения, ВЛАДЕЮЩЕГО подпиской на вебхуки (схема «два приложения»:
# одно для OAuth, другое для вебхуков). Если не задан — используется META_APP_SECRET.
META_WEBHOOK_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=any-random-string-for-webhook-verify
META_CALLBACK_URL=https://your-ngrok-subdomain.ngrok.app/webhooks/instagram

# --- VK ---
VK_API_VERSION=5.199

# --- Server ---
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=info

# --- Asynq monitor (optional) ---
ASYNQ_MONITOR_PORT=8081
